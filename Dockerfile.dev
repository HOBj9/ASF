FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json* ./
RUN npm install

# Copy source code
COPY . .

EXPOSE 3036

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3036
ENV HOSTNAME="0.0.0.0"

# Use Turbopack to reduce ChunkLoadError (chunk timeout) in Docker dev
CMD ["npm", "run", "dev", "--", "--turbo", "-p", "3036", "-H", "0.0.0.0"]

