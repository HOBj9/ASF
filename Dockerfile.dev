FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json* ./
RUN npm install

# Copy source code
COPY . .

EXPOSE 3036

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3036
ENV HOSTNAME="0.0.0.0"

# Run Next.js dev (Turbopack disabled via TURBOPACK=0 to avoid ENOMEM in Docker)
CMD ["npm", "run", "dev", "--", "-p", "3036", "-H", "0.0.0.0"]

